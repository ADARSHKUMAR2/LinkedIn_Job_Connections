# ==========================================
# 1. Core Secrets & Security (CRITICAL)
# ==========================================
# Never allow environmental credential parameters into source control
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.pem
*.key

# ==========================================
# 2. Python & uv Architecture (Backend)
# ==========================================
# Ignore the local virtual runtime environments
backend/.venv/
backend/env/
backend/venv/
backend/ENV/

# Python compiled bytecode & runtime indices
**/__pycache__/
*.py[cod]
*$py.class
*.idx
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ==========================================
# 3. Node & Next.js Architecture (Frontend)
# ==========================================
# Dependency engine suites
frontend/node_modules/
.pnpm-store/

# Next.js compilation distributions and build outputs
frontend/.next/
frontend/out/
frontend/build/

# Runtime tracking and log matrices
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.eslintcache

# ==========================================
# 4. LinkHunter Data & Storage Artifacts
# ==========================================
# Block raw data dumps and dynamic output ledgers from tracking
*.csv
*.xlsx
!backend/app/services/   # Ensure your script directories are never ignored
**/target_jobs.xlsx

# ==========================================
# 5. Global OS & IDE System Profiles
# ==========================================
.DS_Store
Thumbs.db
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp

# Keep custom path interpreters but ignore personal developer workspace settings overrides
.vscode/*
!.vscode/extensions.json
backend/.env
